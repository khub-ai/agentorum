{
  "name": "agentorum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "packages/electron/main.mjs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start":             "node packages/server/server.mjs --open",

    "setup:software-dev": "node packages/server/server.mjs --bundle usecases/software-dev-review/software-dev-review.bundle.json --open",

    "start:vc-debate":   "node packages/server/server.mjs --config examples/vc-debate/agentorum.config.json --open",
    "start:policy":      "node packages/server/server.mjs --config examples/policy-mediation/agentorum.config.json --open",

    "electron":          "electron packages/electron/main.mjs",
    "electron:dev":      "electron packages/electron/main.mjs",
    "electron:dev:vc":   "electron packages/electron/main.mjs --config examples/vc-debate/agentorum.config.json",
    "electron:build":    "electron-builder --config electron-builder.yml",
    "electron:build:win":"electron-builder --config electron-builder.yml --win",
    "electron:build:mac":"electron-builder --config electron-builder.yml --mac",
    "electron:build:linux":"electron-builder --config electron-builder.yml --linux",

    "arc":      "node usecases/arc-agi-ensemble/run.mjs",
    "arc:human":"node usecases/arc-agi-ensemble/run.mjs --human --charts --charts-dir usecases/arc-agi-ensemble/charts"
  },
  "devDependencies": {
    "electron":         "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "ws": "^8.17.0"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
